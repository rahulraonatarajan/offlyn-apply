{
  "name": "offlyn-firefox-extension",
  "version": "0.1.1",
  "description": "Offline-first Firefox WebExtension for job application automation",
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "run:firefox": "web-ext run --source-dir dist",
